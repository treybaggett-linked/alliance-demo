---
import BaseLayout from '../layouts/BaseLayout.astro';
import firm from '../config/firm.json';
---

<BaseLayout firm={firm}>

  <!-- Hero Section -->
  <section class="hero">
    <h1>{firm.hero.headline}</h1>
    <p>{firm.hero.subheadline}</p>
    <a href="#" class="btn">{firm.hero.ctaText}</a>
  </section>

  <!-- Services Section -->
  <section class="services">
    <h2>What we do</h2>
    <p class="section-sub">Services built for businesses like yours.</p>
    <div class="services-grid">
      {firm.services.map((service) => (
        <div class="service-card">
          <div class="icon"></div>
          <h3>{service.title}</h3>
          <p>{service.description}</p>
        </div>
      ))}
    </div>
  </section>

</BaseLayout>